# --- Claude API ---
ANTHROPIC_API_KEY=your_key_here
CLAUDE_MODEL=claude-sonnet-4-6
AGENT_MAX_TOKENS=1024

# --- Mock MotionTools connection ---
MOTIONTOOLS_BASE_URL=http://127.0.0.1:8001

# --- Timing mode ---
# 'production' = real 5/10 minute retry timers
# 'demo'       = shortened for viva demonstrations
TIMING_MODE=demo
DEMO_RETRY_SECONDS_ORDER_NOT_IN_RESTO=30
DEMO_RETRY_SECONDS_ORDER_NOT_READY=45
PROD_RETRY_SECONDS_ORDER_NOT_IN_RESTO=300
PROD_RETRY_SECONDS_ORDER_NOT_READY=600

# --- Audit log ---
AUDIT_LOG_PATH=data/logs/action_log.jsonl

# --- Safety cap ---
MAX_TOOL_CALL_ROUNDS=5

# --- Server (agent will run on port 8002; mock MotionTools is on 8001) ---
HOST=127.0.0.1
PORT=8002
